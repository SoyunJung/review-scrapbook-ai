LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_THINK=false
OLLAMA_TIMEOUT_SECONDS=600
OLLAMA_NUM_PREDICT=3500

STT_MODEL=Systran/faster-whisper-large-v3
STT_DEVICE=cuda
STT_COMPUTE_TYPE=int8_float16

EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_FALLBACK_MODEL=Qwen/Qwen3-Embedding-0.6B

TTS_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
TTS_SPEAKER=Sohee

WIKIPEDIA_CONTEXT_ENABLED=true
WIKIPEDIA_LANGUAGE=en
WIKIPEDIA_TIMEOUT_SECONDS=12
WIKIPEDIA_STORE_MAX_CHARS=100000
WIKIPEDIA_PROMPT_MAX_CHARS=7000
WIKIPEDIA_USER_AGENT=ReflectionScrapbookAI/0.1 (university project; local development)

# Optional OpenAI provider
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_api_key_here
# OPENAI_MODEL=gpt-5.5
